---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<Layout title="Home">
  <section class="hero">
    <div class="container">
      <span class="hero-tag">Thinking out loud</span>
      <h1>Writing that goes<br />where the argument leads.</h1>
      <p>
        I write about ideas at the edges of things — where a concept from physics
        explains a business decision, where a historical pattern maps onto a startup,
        where the obvious answer turns out to be the wrong one.
      </p>
      <a href="/blog" class="post-card" style="display:inline-block; padding: 0.65rem 1.25rem; text-decoration:none; font-weight:700;">
        Read the writing →
      </a>
    </div>
  </section>

  <section class="post-list">
    <div class="container">
      <h2>Recent</h2>
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="post-card">
          <span class="post-card-date">
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
          <h3>{post.data.title}</h3>
          {post.data.description && <p>{post.data.description}</p>}
        </a>
      ))}
      {posts.length === 0 && <p style="color:#666;">First post coming soon.</p>}
    </div>
  </section>
</Layout>
